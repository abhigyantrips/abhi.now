---
import ProjectsLayout from "@/layouts/projects-layout.astro";
import { type CollectionEntry, getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects: CollectionEntry<"projects">[] = await getCollection("projects");

	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<ProjectsLayout
	postTitle={project.data.title}
	postDescription={project.data.description}
	postDate={project.data.startDate.toLocaleString("en-IN", {
		year: "numeric",
		month: "long",
		day: "numeric",
	})}
	postUrl={`/projects/${project.id}`}
>
	<article
		class:list={[
			"e-content prose lg:prose-lg dark:prose-invert max-w-none text-justify text-(--color-text) marker:text-(--color-text)/75",
			"prose-blockquote:text-(--color-text)/75 prose-blockquote:border-l-4 prose-blockquote:border-(--color-text) prose-blockquote:[&>p]:first-of-type:before:content-none prose-blockquote:[&>p]:last-of-type:after:content-none",
			"prose-strong:text-(--color-text) prose-em:text-(--color-text) prose-a:text-(--color-text) prose-a:underline-offset-2 prose-a:decoration-1 prose-a:decoration-(--color-text-muted) prose-a:hover:bg-(--color-text) prose-a:hover:text-(--color-bg) prose-a:*:hover:text-(--color-bg) prose-a:hover:decoration-transparent",
			"prose-headings:text-(--color-text) prose-headings:font-semibold prose-headings:tracking-wide",
			"prose-hr:border-t-2 prose-hr:border-(--color-text-muted)/20 prose-hr:my-8",
			"prose-img:rounded-xl prose-img:border prose-img:border-(--color-text-muted)/20",
		]}
	>
		{
			project.data.links && (
				<div class="prose-a:font-normal prose-a:decoration-dashed">
					<span class="font-semibold">Links:</span>
					{project.data.links?.map((link, i) => (
						<a href={link.url}>{link.label}</a><span>{i < project.data.links!.length - 1 ? ", " : ""}</span>
					))}
				</div>
			)
		}
		{
			project.data.collaborators && (
				<div class="prose-a:font-normal prose-a:decoration-dashed">
					<span class="font-semibold">Collaborators:</span>
					{project.data.collaborators?.map((person, i) => (
						<a href={person.url}>{person.name}</a><span>{i < project.data.collaborators!.length - 1 ? ", " : ""}</span>
					))}
				</div>
			)
		}
		<Content />
	</article>
</ProjectsLayout>
