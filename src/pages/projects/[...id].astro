---
import ProjectsLayout from "@/layouts/projects-layout.astro";
import { type CollectionEntry, getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects: CollectionEntry<"projects">[] = await getCollection("projects");

	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<ProjectsLayout
	postTitle={project.data.title}
	postDescription={project.data.description}
	postStartDate={project.data.startDate}
	postEndDate={project.data.endDate}
	postUrl={`/projects/${project.id}`}
>
	<article class="e-content prose-content">
		{
			project.data.links && (
				project.data.links.length < 3 ? (
				<div class="prose-a:font-normal prose-a:decoration-dashed prose-a:underline-offset-3">
					<span class="font-semibold">Links:</span>
					{project.data.links?.map((link, i) => (
						<a href={link.url}>{link.label}</a><span>{i < project.data.links!.length - 1 ? ", " : ""}</span>
					))}
				</div>
			) : (
				<div>
					<span class="font-semibold">Links:</span>
					<ul class="list-disc list-inside ml-6 not-prose marker:text-(--color-text-muted)/75">
						{project.data.links?.map((link, i) => (
						<li><a class="underline underline-offset-3 decoration-1 decoration-dashed hover:bg-(--color-text) hover:text-(--color-bg) decoration-(--color-text-muted) hover:decoration-transparent" href={link.url}>{link.label}</a></li>
					))}
					</ul>
				</div>
			)
			)
		}
		{
			project.data.collaborators && (
				<div class="prose-a:font-normal prose-a:decoration-dashed prose-a:underline-offset-3">
					<span class="font-semibold">Collaborators:</span>
					{project.data.collaborators?.map((person, i) => (
						<a href={person.url}>{person.name}</a><span>{i < project.data.collaborators!.length - 1 ? ", " : ""}</span>
					))}
				</div>
			)
		}
		<Content />
	</article>
</ProjectsLayout>
