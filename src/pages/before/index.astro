---
import PageLayout from "@/layouts/page-layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const entries = (await getCollection("before")).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<PageLayout route="/before">
	<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
		{
			entries.map((entry) => (
				<a
					href={`/before/${entry.id}`}
					class="group relative block aspect-video overflow-hidden rounded-lg bg-(--color-text) shadow-md hover:scale-105 hover:shadow-2xl dark:bg-(--color-bg)"
				>
					{entry.data.heroImage ? (
						<Image
							src={entry.data.heroImage}
							alt={`Hero image for archive #${entry.id}`}
							class="absolute inset-0 h-full w-full object-cover opacity-50 dark:opacity-30"
						/>
					) : (
						<div class="absolute inset-0 bg-(--color-text-muted)/20" />
					)}
					<div class="relative z-10 flex h-full flex-col justify-between p-4">
						<h3 class="text-2xl font-semibold tracking-wide text-(--color-bg) dark:text-(--color-text)">
							#{entry.id}
						</h3>
						<time
							class="flex justify-end text-sm text-(--color-bg)/70 dark:text-(--color-text-muted)"
							datetime={entry.data.date.toISOString()}
						>
							{entry.data.date.toDateString()}
						</time>
					</div>
				</a>
			))
		}
	</div>
</PageLayout>
