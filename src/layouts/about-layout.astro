---
import BaseHead from "@/components/base-head.astro";
import Container from "@/components/container.astro";
import Header from "@/components/header.astro";
import { slideFromBottom } from "@/lib/transitions";
import { ROUTES, SITE } from "@/consts";
import "@/styles/global.css";
import Footer from "@/components/footer.astro";

const aboutRoute = ROUTES.find((r) => r.PATH === "/whoami" || r.NAME === "whoami");

if (!aboutRoute) {
	throw new Error(`Route "/whoami" not found in ROUTES`);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${aboutRoute.NAME} | ${SITE.TITLE}`} description={aboutRoute.DESCRIPTION} />
	</head>
	<body class="font-gummy">
		<Header section={aboutRoute.NAME} />
		<main
			class="flex min-h-[calc(100vh-(--spacing(48)))] flex-1 flex-col"
			transition:animate={slideFromBottom}
		>
			<Container size="md">
				<div
					class="flex flex-col pt-48"
					style={`--route-color-light: ${aboutRoute.COLOR.LIGHT}; --route-color-dark: ${aboutRoute.COLOR.DARK};`}
				>
					<div class="flex flex-col space-x-6 md:flex-row">
						<div
							class="route-icon-display mb-2 size-14 -rotate-12 md:mb-0 md:size-16"
							style={`-webkit-mask: url(${aboutRoute.ICON}) no-repeat center; mask: url(${aboutRoute.ICON}) no-repeat center; -webkit-mask-size: contain; mask-size: contain;`}
							role="img"
							aria-label={aboutRoute.NAME}
							transition:name={`icon-${aboutRoute.NAME}`}
							transition:persist
						>
						</div>
						<div class="flex flex-col">
							<h1 class="route-title text-3xl font-bold">
								{aboutRoute.NAME}
							</h1>
							<p class="text-(--color-text)">{aboutRoute.DESCRIPTION}</p>
						</div>
					</div>
				</div>
				<hr class="my-8 border-t border-(--color-text-muted)/50 md:my-12" />
				<slot />
			</Container>
		</main>
		<Footer />
	</body>
</html>

<style>
	.route-icon-display {
		background-color: var(--route-color-light);
	}

	.route-title {
		color: var(--route-color-light);
	}

	:global(.dark) .route-icon-display {
		background-color: var(--route-color-dark);
	}

	:global(.dark) .route-title {
		color: var(--route-color-dark);
	}
</style>
