---
import PageLayout from "@/layouts/page-layout.astro";
import WeeknotesView from "@/components/weeknotes-view.astro";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { getCollection } from "astro:content";

const entries = await getCollection("before");
const weeknotes = await getCollection("weeknotes");

const latestEntry = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
const { Content } = await render(latestEntry);

const weeknotesSince = weeknotes.filter(
	(note) => note.data.fromDate.getTime() >= latestEntry.data.date.getTime()
);
---

<PageLayout route="/now">
	<article class="prose-content">
		<span><strong>Last Updated:</strong> {latestEntry.data.date.toLocaleString("en-IN")}</span>
		{
			latestEntry.data.heroImage && (
				<Image
					src={latestEntry.data.heroImage}
					alt={`Hero image for archive #${latestEntry.id}`}
					class="w-full rounded-xl border border-(--color-text-muted)/20"
				/>
			)
		}
		<Content />
		<div class="flex items-baseline justify-between">
			<h2>weeknotes since.</h2>
			<a
				href="/weeknotes"
				class="not-prose text-sm text-(--color-text-muted) underline decoration-(--color-text-muted) decoration-dotted decoration-2 underline-offset-4 hover:text-(--color-text) hover:decoration-solid"
			>
				view all
			</a>
		</div>
		<div class="not-prose">
			<WeeknotesView entries={weeknotesSince} />
		</div>
		<div class="flex items-baseline justify-between">
			<h2>before.</h2>
			<a
				href="/before"
				class="not-prose text-sm text-(--color-text-muted) underline decoration-(--color-text-muted) decoration-dotted decoration-2 underline-offset-4 hover:text-(--color-text) hover:decoration-solid"
			>
				view all
			</a>
		</div>
		<div class="not-prose grid grid-cols-1 gap-4 md:grid-cols-3">
			{
				entries.length > 1 ? (
					entries.slice(1, 4).map((entry) => (
						<a href={`/before/${entry.id}`} class="group relative block overflow-hidden rounded-lg">
							{entry.data.heroImage ? (
								<Image
									src={entry.data.heroImage}
									alt={`Hero image for archive #${entry.id}`}
									class="absolute inset-0 h-full w-full object-cover opacity-20 transition-opacity duration-200 group-hover:opacity-30"
								/>
							) : (
								<div class="absolute inset-0 bg-(--color-text-muted)/20" />
							)}
							<div class="relative z-10 p-4">
								<h3 class="font-semibold tracking-wide text-(--color-text)">#{entry.data.title}</h3>
								<time
									class="text-sm text-(--color-text-muted)"
									datetime={entry.data.date.toISOString()}
								>
									{entry.data.date.toDateString()}
								</time>
								<p class="mt-2 text-sm text-(--color-text)">{entry.data.description}</p>
							</div>
						</a>
					))
				) : (
					<p class="col-span-3 text-(--color-text-muted) italic">
						looks like the only moment that exists is now.
					</p>
				)
			}
		</div>
		{}
	</article>
</PageLayout>
