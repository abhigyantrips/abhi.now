---
import PageLayout from "@/layouts/page-layout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("blog");
---

<PageLayout route="/blog">
	<div class="h-feed grid grid-cols-[auto_1fr] items-baseline gap-x-4 gap-y-2">
		<span class="p-name col-span-2 hidden">abhigyan trips's blog</span>
		{
			entries.map((post: any) => (
				<div class="h-entry contents">
					<time
						class="dt-published text-sm text-(--color-text-muted)"
						datetime={post.data.date.toISOString()}
					>
						{post.data.date.toISOString().slice(0, 10)}
					</time>
					<a class="p-name u-url" href={`/blog/${post.id}`}>
						<span class="decoration-2 underline-offset-4 hover:underline">{post.data.title}</span>
					</a>
				</div>
			))
		}
	</div>
</PageLayout>
