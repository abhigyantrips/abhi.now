---
import type { CollectionEntry } from "astro:content";

type Props = {
	entries: CollectionEntry<"weeknotes">[];
	isDescending?: boolean;
};

const { entries, isDescending = false } = Astro.props;

const days = ["sun", "mon", "tue", "wed", "thu", "fri", "sat"] as const;

const sortedEntries = [...entries].sort(
	(a, b) => a.data.fromDate.getTime() - b.data.fromDate.getTime()
);

if (isDescending) {
	sortedEntries.reverse();
}

function formatShortDate(d: Date) {
	return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

// Month colors in a smooth gradient (Jan → Dec)
const MONTH_COLORS = [
	"#E06C75", // jan - rose
	"#D19A66", // feb - amber
	"#E5C07B", // mar - gold
	"#98C379", // apr - green
	"#56B6C2", // may - teal
	"#61AFEF", // jun - sky
	"#528BFF", // jul - blue
	"#7C6FE1", // aug - indigo
	"#C678DD", // sep - purple
	"#E06CB0", // oct - magenta
	"#D16969", // nov - coral
	"#BE5046", // dec - rust
] as const;

function getMonthColor(date: Date) {
	return MONTH_COLORS[date.getMonth()];
}
---

<div class="weeknotes-view relative flex flex-col gap-0">
	<!-- Weekday header row -->
	<div class="hidden justify-around border-b border-(--color-text-muted)/20 pb-3 md:flex">
		{
			days.map((day) => (
				<span class="w-10 text-center text-xs font-semibold tracking-widest text-(--color-text-muted) uppercase">
					{day}
				</span>
			))
		}
	</div>

	<!-- Timeline + cards area -->
	<div class="relative">
		<!-- Vertical lines (hidden on mobile) -->
		<div
			class="pointer-events-none absolute inset-0 hidden justify-around md:flex"
			aria-hidden="true"
		>
			{
				days.map(() => (
					<div class="flex w-10 justify-center">
						<div class="h-full w-px border-l border-dashed border-(--color-text-muted)/20" />
					</div>
				))
			}
		</div>

		<!-- Cards -->
		<div class="relative z-10 flex flex-col gap-4 py-4">
			{
				sortedEntries.length > 0 ? (
					sortedEntries.map((note) => {
						const href = `/weeknotes/${note.id}`;

						const match = note.data.title.match(/^(\([^)]+\))\s*(.*)$/);
						const noteId = match ? match[1] : note.data.title;
						const noteTitle = match ? match[2] : "";
						const monthColor = getMonthColor(note.data.fromDate);

						return (
							<a
								href={href}
								class="group block rounded-lg bg-(--color-text)/10 p-4 transition-colors duration-100 hover:bg-[color-mix(in_srgb,var(--month-color)_15%,transparent)] md:px-6 md:py-5"
								style={`--month-color: ${monthColor};`}
							>
								<h3 class="flex items-center justify-between gap-4 font-semibold tracking-wide text-(--color-text) decoration-2 underline-offset-4">
									<span class="text-sm" style={`color: ${monthColor};`}>
										{noteId}
									</span>
									{noteTitle && <span class="text-right">{noteTitle}</span>}
								</h3>
								<div class="mt-2 flex items-center gap-2 text-sm text-(--color-text-muted)">
									<time datetime={note.data.fromDate.toISOString()}>
										{formatShortDate(note.data.fromDate)}
									</time>
									<span class="h-0.5 flex-1 rounded-full bg-(--color-text-muted)/40 transition-colors duration-100 group-hover:bg-(--month-color)" />
									<time datetime={note.data.toDate.toISOString()}>
										{formatShortDate(note.data.toDate)}
									</time>
								</div>
							</a>
						);
					})
				) : (
					<p class="py-4 text-(--color-text-muted) italic">no weeknotes yet. check back soon!</p>
				)
			}
		</div>
	</div>
</div>
