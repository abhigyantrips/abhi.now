---
import BaseHead from "@/components/base-head.astro";
import Container from "@/components/container.astro";
import Footer from "@/components/footer.astro";
import Header from "@/components/header.astro";
import { slideFromBottom } from "@/lib/transitions";
import { ROUTES, SITE } from "@/consts";
import "@/styles/global.css";
import "@/styles/prose.css";

type Props = {
	route: string;
	post: {
		title: string;
		description: string;
		date: string;
		readingTime?: string;
		url: string;
	};
};

const { route, post } = Astro.props;

const currentRoute = ROUTES.find((r) => r.PATH === route || r.NAME === route);

if (!currentRoute) {
	throw new Error(`Route "${route}" not found in ROUTES`);
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${post.title.toLowerCase()} | ${SITE.TITLE}`}
			description={post.description}
		/>
	</head>
	<body class="font-gummy">
		<Header section={currentRoute.NAME} />
		<main
			class="flex min-h-[calc(100vh-(--spacing(56)))] flex-1 flex-col pb-12 md:pb-36"
			transition:animate={slideFromBottom}
		>
			<Container size="md">
				<div class="h-entry flex flex-col pt-24 md:pt-48">
					<div class="flex flex-col gap-2">
						{
							(post.date || post.readingTime) && (
								<div class="flex items-center gap-2 text-sm text-(--color-text-muted) uppercase">
									{post.date && (
										<time class="dt-published" datetime={post.date}>
											{post.date}
										</time>
									)}
									{post.date && post.readingTime && <span aria-hidden="true">·</span>}
									{post.readingTime && <span>{post.readingTime}</span>}
								</div>
							)
						}
						<h1 class="p-name text-3xl font-semibold">
							{post.title}
						</h1>
						<p class="p-summary text-(--color-text-muted)">{post.description}</p>
						{
							post.url && (
								<a class="u-url hidden" href={post.url}>
									{post.title}
								</a>
							)
						}
						<span class="p-author h-card hidden">
							<a class="p-name u-url" href={SITE.URL} rel="author">{SITE.AUTHOR}</a>
						</span>
					</div>
					<hr class="mt-4 border-t border-(--color-text-muted)/50" />
					<slot />
				</div>
			</Container>
		</main>

		<Footer />
	</body>
</html>
