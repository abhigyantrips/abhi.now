---
import { getCollection, render } from "astro:content";
import WeeknoteLayout from "@/layouts/weeknote-layout.astro";

export async function getStaticPaths() {
	const notes = await getCollection("weeknotes");
	return notes.map((note) => {
		const [year, week] = note.id.split("/");
		return {
			params: { year, week },
			props: { note },
		};
	});
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<WeeknoteLayout
	title={note.data.title}
	description={note.data.description}
	fromDate={note.data.fromDate}
	toDate={note.data.toDate}
	postUrl={`/weeknotes/${note.id}`}
>
	<article class="e-content prose-content">
		<Content />
	</article>
</WeeknoteLayout>
