---
import EvilEye from "@/components/evil-eye.astro";
import HCard from "@/components/h-card.astro";

const showWhoamiEvilEye =
	Astro.url.pathname === "/whoami" || Astro.url.pathname.startsWith("/whoami/");
---

<div
	data-site-footer
	class="font-gummy flex items-end justify-center px-6 py-6 text-(--color-text-muted) lg:grid lg:grid-cols-[1fr_auto_1fr] lg:items-end lg:px-8"
>
	<div class="hidden lg:block lg:justify-self-start">
		<HCard />
	</div>
	<div class="flex flex-col items-center gap-2">
		<div class="webring flex items-center gap-2">
			<a
				href="https://blr.indiewebclub.org/webring/previous.html"
				aria-label="Previous site in webring"
				class="size-4 text-(--color-text-muted) hover:scale-110"
			>
				<span
					class="chevron-icon size-4"
					style="--icon-url: url(/icons/chevrons-left.svg);"
				></span>
			</a>
			<a
				href="https://blr.indiewebclub.org/"
				target="_blank"
				rel="noopener noreferrer"
				class="underline decoration-dashed underline-offset-4 hover:decoration-solid"
			>
				IndieWebClub Bangalore
			</a>
			<a
				href="https://blr.indiewebclub.org/webring/next.html"
				aria-label="Next site in webring"
				class="size-4 text-(--color-text-muted) hover:scale-110"
			>
				<span
					class="chevron-icon size-4"
					style="--icon-url: url(/icons/chevrons-right.svg);"
				></span>
			</a>
		</div>

		<p>copyright &copy; {new Date().getFullYear()}, abhigyan trips.</p>
	</div>
	<div class="hidden items-center gap-2 lg:flex lg:justify-self-end">
		{showWhoamiEvilEye && <EvilEye variant="inline" />}
		<button
			id="scroll-to-top"
			class="flex size-10 cursor-pointer items-center justify-center rounded-full bg-(--color-text) text-(--color-bg) hover:scale-110"
			aria-label="Scroll to top"
		>
			<span
				class="scroll-icon size-5"
				style="--icon-url: url(/icons/chevrons-up.svg);"
			></span>
		</button>
	</div>
</div>

<style>
	.scroll-icon,
	.chevron-icon {
		display: inline-block;
		background-color: currentColor;
		-webkit-mask-image: var(--icon-url);
		mask-image: var(--icon-url);
		-webkit-mask-size: contain;
		mask-size: contain;
		-webkit-mask-repeat: no-repeat;
		mask-repeat: no-repeat;
		-webkit-mask-position: center;
		mask-position: center;
	}
</style>

<script>
	let evilEyeFooterObserver: IntersectionObserver | undefined;
	let evilEyeDesktopQuery: MediaQueryList | undefined;
	let evilEyeFooterVisible = false;
	let evilEyeStickyElements: NodeListOf<HTMLElement> | undefined;
	let evilEyeFooterElements: NodeListOf<HTMLElement> | undefined;

	const syncEvilEyeDock = () => {
		const shouldDock = evilEyeFooterVisible && Boolean(evilEyeDesktopQuery?.matches);

		evilEyeStickyElements?.forEach((element) => {
			element.toggleAttribute("data-footer-visible", shouldDock);
		});

		evilEyeFooterElements?.forEach((element) => {
			element.toggleAttribute("data-footer-visible", shouldDock);
		});
	};

	function setupScrollToTop() {
		const scrollBtn = document.getElementById("scroll-to-top");

		scrollBtn?.addEventListener("click", () => {
			window.scrollTo({
				top: 0,
				behavior: "smooth",
			});
		});
	}

	function setupEvilEyeDock() {
		evilEyeFooterObserver?.disconnect();
		evilEyeDesktopQuery?.removeEventListener("change", syncEvilEyeDock);

		evilEyeFooterVisible = false;
		evilEyeStickyElements = document.querySelectorAll("[data-evil-eye-sticky]");
		evilEyeFooterElements = document.querySelectorAll("[data-evil-eye-footer]");

		if (!evilEyeStickyElements.length || !evilEyeFooterElements.length) {
			syncEvilEyeDock();
			return;
		}

		const footer = document.querySelector("[data-site-footer]");

		if (!footer) return;

		evilEyeDesktopQuery = window.matchMedia("(min-width: 1024px)");
		evilEyeDesktopQuery.addEventListener("change", syncEvilEyeDock);

		evilEyeFooterObserver = new IntersectionObserver(
			([entry]) => {
				evilEyeFooterVisible = entry.isIntersecting;
				syncEvilEyeDock();
			},
			{ threshold: 0.25 }
		);

		evilEyeFooterObserver.observe(footer);
	}

	document.addEventListener("astro:page-load", setupScrollToTop);
	document.addEventListener("astro:page-load", setupEvilEyeDock);
</script>
